alert tcp any any -> $HOME_NET any (msg:"LAB - Posible escaneo SYN detectado"; flags:S; threshold:type both, track by_src, count 50, seconds 10; sid:1000001; rev:1; classtype:attempted-recon;)
alert tcp any any -> $HOME_NET any (msg:"LAB - Posible NULL scan"; flags:0; threshold:type both, track by_src, count 20, seconds 10; sid:1000002; rev:1; classtype:attempted-recon;)
alert tcp any any -> $HOME_NET any (msg:"LAB - Posible XMAS scan"; flags:FPU; threshold:type both, track by_src, count 20, seconds 10; sid:1000003; rev:1; classtype:attempted-recon;)
alert tcp any any -> $HOME_NET 22 (msg:"LAB - Posible fuerza bruta SSH"; flow:to_server,established; threshold:type both, track by_src, count 10, seconds 60; sid:1000004; rev:1; classtype:attempted-admin;)
alert dns any any -> any any (msg:"LAB - Volumen alto de consultas DNS"; threshold:type both, track by_src, count 100, seconds 60; sid:1000005; rev:1; classtype:bad-unknown;)
alert http any any -> $HOME_NET any (msg:"LAB - Intento acceso directorio admin"; http.method; content:"GET"; http.uri; content:"/admin"; nocase; sid:1000006; rev:1; classtype:web-application-attack;)
alert http any any -> $HOME_NET any (msg:"LAB - Posible path traversal"; http.method; content:"GET"; http.uri; content:"../"; sid:1000007; rev:1; classtype:web-application-attack;)
alert http any any -> $HOME_NET any (msg:"LAB - User-Agent Nmap detectado"; http.user_agent; content:"Nmap"; nocase; sid:1000008; rev:1; classtype:attempted-recon;)
alert udp any any -> $HOME_NET any (msg:"LAB - Posible escaneo UDP"; threshold:type both, track by_src, count 50, seconds 10; sid:1000009; rev:1; classtype:attempted-recon;)